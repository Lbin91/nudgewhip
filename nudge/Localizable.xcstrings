    "menu.status.detail.alerting": {
      "comment": "Helper text shown while alert escalation is active.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Nudge escalation is active until activity returns."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "사용자 활동이 돌아올 때까지 넛지 에스컬레이션이 진행됩니다."
          }
        }
      }
    },
    "menu.status.detail.limited_no_ax": {
      "comment": "Helper text shown when Accessibility permission is missing.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Accessibility permission is needed for active idle detection."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "실제 무입력 감지를 위해 손쉬운 사용 권한이 필요합니다."
          }
        }
      }
    },
    "menu.status.detail.monitoring": {
      "comment": "Helper text shown while monitoring is active.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Idle countdown is running with the current threshold."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "현재 기준 시간으로 무입력 카운트다운이 진행 중입니다."
          }
        }
      }
    },
    "menu.status.detail.paused_manual": {
      "comment": "Helper text shown while manual pause is active.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Manual pause is active, so idle alerts are stopped."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "수동 휴식 상태라서 무입력 알림이 멈춰 있습니다."
          }
        }
      }
    },
    "menu.status.detail.paused_whitelist": {
      "comment": "Helper text shown while a whitelisted app is frontmost.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A whitelisted app is frontmost, so monitoring is paused."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "화이트리스트 앱이 전면에 있어 모니터링이 일시중지되었습니다."
          }
        }
      }
    },
    "menu.status.detail.suspended": {
      "comment": "Helper text shown while monitoring is suspended due to sleep or lock.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Monitoring is suspended while the Mac is asleep, locked, or switched away."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Mac이 잠자기, 잠금 또는 빠른 사용자 전환 상태라 모니터링이 중단되었습니다."
          }
        }
      }
    },
