    "alert.message.gentle_nudge" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You have been idle for a bit. Let’s get back into focus."
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "조금 자리를 비웠어요. 다시 집중 흐름으로 돌아가볼까요?"
          }
        }
      }
    },
    "alert.message.gentle_nudge.1" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The flow paused. Coming back now will be easy."
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "흐름이 잠시 끊겼습니다. 지금 돌아오면 이어가기 쉽습니다."
          }
        }
      }
    },
    "alert.message.gentle_nudge.2" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "I'll hold the line a little longer. Let's start again."
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "조금만 더 붙잡아 두겠습니다. 다시 시작해 봅시다."
          }
        }
      }
    },
    "alert.message.gentle_nudge.3" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A brief detour. You can find your way back from here."
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "잠시 빗나갔네요. 여기서 방향을 잡으면 됩니다."
          }
        }
      }
    },
